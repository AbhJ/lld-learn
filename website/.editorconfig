# EditorConfig for LLD Learn Website
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Use tabs for all code files
[*.{html,css,js}]
indent_style = tab
indent_size = 4

# Markdown can use spaces for lists
[*.md]
indent_style = tab
indent_size = 4
trim_trailing_whitespace = false

# JSON files use tabs
[*.json]
indent_style = tab
indent_size = 4

# Shell scripts use tabs
[*.sh]
indent_style = tab
indent_size = 4

# Text files
[*.txt]
indent_style = tab
